@page "/details"
@using System.ComponentModel.DataAnnotations
@using System.Text.Json
@inject ProfileService ProfileService
@inject NavigationManager Navigation
@inject HttpClient Http
@layout AuthLayout

<div class="auth-header">
    <h2>Lets get to know you...</h2>
    <p>Let us know more about you and what you like. This is all optional.</p>
</div>

<EditForm Model="@registerData"
          OnSubmit="@HandleRegister"
          class="auth-form">

    <DataAnnotationsValidator />

    <div class="form-group">
        <label><i class="fas fa-pen"></i> Bio</label>

        <InputTextArea class="form-control"
                       @bind-Value="registerData.Bio"
                       placeholder="Tell us about yourself...">
        </InputTextArea>

        <ValidationMessage For="@(() => registerData.Bio)" />
    </div>

    <div class="form-group">
        <label><i class="fas fa-map-marker-alt"></i> Location</label>

        <InputSelect class="form-control"
                     @bind-Value="registerData.Location">
            <option value="">Select...</option>
            @foreach (var city in FilteredCities)
            {
                <option>@city</option>
            }
        </InputSelect>

        <ValidationMessage For="@(() => registerData.Location)" />
    </div>

    <div class="form-group">
        <label><i class="fas fa-venus-mars"></i> Gender</label>

        <InputSelect class="form-control"
                        @bind-Value="registerData.Gender">
            <option value="">Select...</option>
            <option>Male</option>
            <option>Female</option>
            <option>Other</option>
        </InputSelect>

        <ValidationMessage For="@(() => registerData.Gender)" />
    </div>

    <div class="form-group">
        <label><i class="fas fa-heart"></i> Interested In</label>

        <InputSelect class="form-control"
                        @bind-Value="registerData.LookingFor">
            <option value="">Select...</option>
            <option>Male</option>
            <option>Female</option>
            <option>Everyone</option>
        </InputSelect>

        <ValidationMessage For="@(() => registerData.LookingFor)" />
    </div>

    <div class="form-group">
        <label><i class="fa-solid fa-eye-dropper"></i> Hair Colour</label>

        <InputSelect class="form-control"
                     @bind-Value="registerData.HairColor">
            <option value="">Select...</option>
            <option>Black</option>
            <option>Brown</option>
            <option>Blonde</option>
            <option>Red</option>
            <option>Auburn</option>
            <option>Grey</option>
            <option>White</option>
            <option>Other</option>
        </InputSelect>

        <ValidationMessage For="@(() => registerData.HairColor)" />
    </div>

    <div class="form-group">
        <label><i class="fa-solid fa-eye-dropper"></i> Skin Tone</label>

        <InputSelect class="form-control"
                     @bind-Value="registerData.SkinTone">
            <option value="">Select...</option>
            <option>Fair</option>
            <option>Light</option>
            <option>Medium</option>
            <option>Olive</option>
            <option>Tan</option>
            <option>Dark</option>
        </InputSelect>

        <ValidationMessage For="@(() => registerData.SkinTone)" />
    </div>

    <div class="form-group">
        <label><i class="fa-solid fa-eye-dropper"></i> Eye Colour</label>

        <InputSelect class="form-control"
                     @bind-Value="registerData.EyeColor">
            <option value="">Select...</option>
            <option>Brown</option>
            <option>Blue</option>
            <option>Green</option>
            <option>Hazel</option>
            <option>Grey</option>
            <option>Amber</option>
        </InputSelect>

        <ValidationMessage For="@(() => registerData.EyeColor)" />
    </div>

    <div class="form-group">
        <label><i class="fa-solid fa-person"></i> Body Size</label>

        <InputSelect class="form-control"
                     @bind-Value="registerData.BodyType">
            <option value="">Select...</option>
            <option>Slim</option>
            <option>Athletic</option>
            <option>Average</option>
            <option>Curvy</option>
            <option>Muscular</option>
            <option>Plus sized</option>
        </InputSelect>

        <ValidationMessage For="@(() => registerData.BodyType)" />
    </div>

    <div class="form-group">
        <label><i class="fa-solid fa-earth-europe"></i> Ethnicity</label>

        <InputSelect class="form-control"
                     @bind-Value="registerData.Ethnicity">
            <option value="">Select...</option>
            <option>White</option>
            <option>Black</option>
            <option>Asian</option>
            <option>Hispanic</option>
            <option>Middle eastern</option>
            <option>Mixed</option>
        </InputSelect>

        <ValidationMessage For="@(() => registerData.Ethnicity)" />
    </div>

    <div class="form-group">
        <label><i class="fa-solid fa-smoking"></i> Smoking</label>

        <InputSelect class="form-control"
                     @bind-Value="registerData.Smoking">
            <option value="">Select...</option>
            <option>Never</option>
            <option>Rarely</option>
            <option>Socially</option>
            <option>Occasionally</option>
            <option>Regularly</option>
        </InputSelect>

        <ValidationMessage For="@(() => registerData.Smoking)" />
    </div>

    <div class="form-group">
        <label><i class="fa-solid fa-champagne-glasses"></i> Drinking</label>

        <InputSelect class="form-control"
                     @bind-Value="registerData.Drinking">
            <option value="">Select...</option>
            <option>Never</option>
            <option>Rarely</option>
            <option>Socially</option>
            <option>Occasionally</option>
            <option>Regularly</option>
        </InputSelect>

        <ValidationMessage For="@(() => registerData.Drinking)" />
    </div>

    <button type="submit" class="btn btn-primary btn-block">
        <span>Create Account</span>
        <i class="fas fa-check"></i>
    </button>

</EditForm>

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="message success">@successMessage</div>
}

<div class="auth-footer">
    <p>
        Already have an account?
        <NavLink href="/login">Sign In</NavLink>
    </p>
</div>

@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject ProfileService ProfileService

@code {
    private ProfileModel registerData = new();

    private Dictionary<string, List<string>> CountriesCities = new();
    private List<string> Countries => CountriesCities.Keys.OrderBy(c => c).ToList();
    private List<string> FilteredCities = new();

    private string successMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Load countries JSON
            var response = await Http.GetAsync("/data/countries.min.json");

            if (!response.IsSuccessStatusCode) return;

            var json = await response.Content.ReadAsStringAsync();
            CountriesCities = JsonSerializer.Deserialize<Dictionary<string, List<string>>>(json) ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Failed to load countries JSON: {ex.Message}");
        }
    }

    private void OnCountryChanged(ChangeEventArgs e)
    {
        if (e.Value is string selectedCountry && !string.IsNullOrWhiteSpace(selectedCountry))
        {
            FilteredCities = CountriesCities.TryGetValue(selectedCountry, out var cities)
                ? cities.OrderBy(c => c).ToList()
                : new List<string>();
            registerData.Location = string.Empty;
        }
        else
        {
            FilteredCities = new List<string>();
            registerData.Location = string.Empty;
        }
    }

    private async Task HandleRegister()
    {
        try
        {
            // Get the current user's ID from JWT token
            var currentUserId = await GetCurrentUserIdFromTokenAsync();
            registerData.UserId = currentUserId;

            // Create the profile
            await ProfileService.CreateProfileAsync(registerData);

            successMessage = "Account created successfully!";
            Navigation.NavigateTo("/home", true);
        }
        catch (Exception ex)
        {
            successMessage = $"Error creating account: {ex.Message}";
        }
    }

    private async Task<int> GetCurrentUserIdFromTokenAsync()
    {
        var token = await JS.InvokeAsync<string>("localStorage.getItem", "authToken");
        if (string.IsNullOrEmpty(token))
            throw new Exception("User not logged in");

        var handler = new System.IdentityModel.Tokens.Jwt.JwtSecurityTokenHandler();
        var jwt = handler.ReadJwtToken(token);

        var userIdClaim = jwt.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.NameIdentifier);
        if (userIdClaim == null)
            throw new Exception("User ID claim not found in token");

        return int.Parse(userIdClaim.Value);
    }
}