@page "/register"
@using System.ComponentModel.DataAnnotations

<!--
    REGISTER PAGE (Frontend Only)
    - Uses EditForm with DataAnnotations validation
    - Includes manual password match validation
    - Shows both error and success messages
-->


                <div class="login-container">
                    <div class="login-card">

                        <!-- Branding -->
                        <h2 class="app-title"> Pairly</h2>
                        <p class="subtitle">Create your account</p>

                        <EditForm Model="@registerData" OnValidSubmit="@HandleRegister">

                            <!-- Enables DataAnnotations validation -->
                            <DataAnnotationsValidator />

                            <!-- Shows validation summary (top-level errors) -->
                            <ValidationSummary />

                            <div class="all-inputs">

                                <!-- FIRST NAME -->
                                <div class="form-group">
                                    <label>First Name *</label>
                                    <InputText class="form-control"
                                                @bind-Value="registerData.FirstName"
                                                placeholder="Al" />
                                    <ValidationMessage For="@(() => registerData.FirstName)" />
                                </div>

                                <!-- LAST NAME -->
                                <div class="form-group">
                                    <label>Last Name (optional)</label>
                                    <InputText class="form-control"
                                                @bind-Value="registerData.LastName"
                                                placeholder="Saiyed" />
                                    <ValidationMessage For="@(() => registerData.LastName)" />
                                </div>

                                <!-- EMAIL -->
                                <div class="form-group">
                                    <label>Email *</label>
                                    <InputText class="form-control"
                                                @bind-Value="registerData.Email"
                                                placeholder="you@email.com" />
                                    <ValidationMessage For="@(() => registerData.Email)" />
                                </div>

                                <!-- AGE -->
                                <div class="form-group">
                                    <label>Age *</label>
                                    <InputText class="form-control"
                                                @bind-Value="registerData.Age"
                                                placeholder="DD/MM/YYYY" />
                                    <ValidationMessage For="@(() => registerData.Age)" />
                                </div>

                                <!-- PASSWORD -->
                                <div class="form-group">
                                    <label>Password *</label>
                                    <InputText type="password"
                                                class="form-control"
                                                @bind-Value="registerData.Password"
                                                placeholder="Minimum 6 characters" />
                                    <ValidationMessage For="@(() => registerData.Password)" />
                                </div>

                                <!-- CONFIRM PASSWORD -->
                                <div class="form-group">
                                    <label>Confirm Password *</label>
                                    <InputText type="password"
                                                class="form-control"
                                                @bind-Value="registerData.ConfirmPassword"
                                                placeholder="Re-enter password" />
                                    <ValidationMessage For="@(() => registerData.ConfirmPassword)" />
                                </div>

                                <!-- PHONE NUMBER -->
                                <div class="form-group">
                                    <label>Phone (optional)</label>
                                    <InputText class="form-control"
                                                @bind-Value="registerData.Phone"
                                                placeholder="07123456789" />
                                    <ValidationMessage For="@(() => registerData.Phone)" />
                                </div>

                                <!-- ADDRESS -->
                                <div class="form-group">
                                    <label>Address (optional)</label>
                                    <InputText class="form-control"
                                                @bind-Value="registerData.Address"
                                                placeholder="123 Street Lane" />
                                    <ValidationMessage For="@(() => registerData.Address)" />
                                </div>

                                <!-- Submit Button (inside grid so it can span columns and be centered) -->
                                <div class="form-actions">
                                    <button type="submit" class="btn-login">Register</button>
                                </div>

                            </div>

                        </EditForm>

                    </div>
                </div>

<!-- Custom Error Message (for password mismatch) -->
@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="message error">
        @errorMessage
    </div>
}

<!-- Success Message -->
@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="message success">
        @successMessage
    </div>
}

<!-- Link back to login -->
<div class="register-link">
    Already have an account?
    <a href="/login">Log in</a>
</div>

@code {

    /*
        RegisterModel:
        Defines the structure of registration data.
        Uses DataAnnotations for frontend validation rules.
    */
    private sealed class RegisterModel
    {
        [Required(ErrorMessage = "First name is required.")]
        [MinLength(2, ErrorMessage = "First name must be at least 2 characters.")]
        public string FirstName { get; set; } = string.Empty;

        [MinLength(2, ErrorMessage = "Last name must be at least 2 characters.")]
        public string LastName { get; set; } = string.Empty;

        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Enter a valid email address.")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Password is required.")]
        [MinLength(6, ErrorMessage = "Password must be at least 6 characters.")]
        public string Password { get; set; } = string.Empty;

        [Required(ErrorMessage = "Confirm password is required.")]
        public string ConfirmPassword { get; set; } = string.Empty;

        // FIX: Add Phone and Address properties so bindings compile
        [Phone(ErrorMessage = "Enter a valid phone number.")]
        public string Phone { get; set; } = string.Empty;

        public string Address { get; set; } = string.Empty;

		[Required(ErrorMessage = "Age is required.")]
		public string Age { get; set; } = string.Empty;
    }

    // Instance of form model
    private RegisterModel registerData = new();

    // Custom error message (for password mismatch)
    private string errorMessage = string.Empty;

    // Success message
    private string successMessage = string.Empty;

    /*
        HandleRegister()
        Runs ONLY when DataAnnotations validation passes.
        We add extra logic to check password match.
    */
    private void HandleRegister()
    {
        // Clear previous messages
        errorMessage = string.Empty;
        successMessage = string.Empty;

        // Manual validation: Password must match ConfirmPassword
        if (!string.Equals(registerData.Password, registerData.ConfirmPassword))
        {
            errorMessage = "Passwords do not match.";
            return;
        }

        // If everything is valid (frontend demo only)
        successMessage = "Account created successfully (front-end demo).";

        // Later:
        // Send registerData to backend API
        // await Http.PostAsJsonAsync("api/auth/register", registerData);
    }
}
