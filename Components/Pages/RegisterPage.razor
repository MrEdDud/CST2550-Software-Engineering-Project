@page "/register"
@using System.ComponentModel.DataAnnotations

<div class="auth-page register-page">
    <div class="auth-container">

        <div class="auth-brand">
            <div class="brand-content">

                <div class="brand-logo">
                    <i class="fas fa-heart"></i>
                </div>

                <h1>Pairly</h1>
                <p>Join thousands of singles finding love and meaningful connections every day. (18+)</p>

                <div class="brand-stats">
                    <div class="stat">
                        <span class="stat-number">Since 2024</span>
                    </div>
                    <div class="stat">
                        <span class="stat-number">Active Today</span>
                    </div>
                    <div class="stat">
                        <span class="stat-number">Verified</span>
                    </div>
                </div>

            </div>
        </div>

        <div class="auth-form-container">
            <div class="auth-form-wrapper">

                <div class="auth-header">
                    <h2>Create Account</h2>
                    <p>Start your journey to find love on Pairly</p>
                </div>

                <EditForm Model="@registerData"
                          OnValidSubmit="@HandleRegister"
                          class="auth-form">

                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="form-group">
                        <label><i class="fas fa-user"></i> Username</label>

                        <InputText class="form-control"
                                   @bind-Value="registerData.Username"
                                   placeholder="Choose a unique username" />

                        <ValidationMessage For="@(() => registerData.Username)" />
                    </div>

                    <div class="form-group">
                        <label><i class="fas fa-envelope"></i> Email</label>

                        <InputText class="form-control"
                                   @bind-Value="registerData.Email"
                                   placeholder="your@email.com" />

                        <ValidationMessage For="@(() => registerData.Email)" />
                    </div>

                    <div class="form-group">
                        <label><i class="fas fa-lock"></i> Password</label>

                        <InputText type="password"
                                   class="form-control"
                                   @bind-Value="registerData.Password"
                                   placeholder="Create a strong password" />

                        <ValidationMessage For="@(() => registerData.Password)" />
                    </div>

                    <div class="form-group">
                        <label><i class="fas fa-id-card"></i> Your Name</label>

                        <InputText class="form-control"
                                   @bind-Value="registerData.Name"
                                   placeholder="What should we call you?" />

                        <ValidationMessage For="@(() => registerData.Name)" />
                    </div>

                    <div class="form-row">

                        <div class="form-group">
                            <label><i class="fas fa-birthday-cake"></i> Age</label>

                            <InputNumber class="form-control"
                                         @bind-Value="registerData.Age" />

                            <ValidationMessage For="@(() => registerData.Age)" />
                        </div>

                        <div class="form-group">
                            <label><i class="fas fa-venus-mars"></i> Gender</label>

                            <InputSelect class="form-control"
                                         @bind-Value="registerData.Gender">
                                <option value="">Select...</option>
                                <option>Male</option>
                                <option>Female</option>
                                <option>Other</option>
                            </InputSelect>

                            <ValidationMessage For="@(() => registerData.Gender)" />
                        </div>

                    </div>

                    <div class="form-group">
                        <label><i class="fas fa-heart"></i> Interested In</label>

                        <InputSelect class="form-control"
                                     @bind-Value="registerData.LookingFor">
                            <option value="">Select...</option>
                            <option>Male</option>
                            <option>Female</option>
                            <option>Everyone</option>
                        </InputSelect>

                        <ValidationMessage For="@(() => registerData.LookingFor)" />
                    </div>

                    <button type="submit" class="btn btn-primary btn-block">
                        <span>Create Account</span>
                        <i class="fas fa-check"></i>
                    </button>

                </EditForm>

                @if (!string.IsNullOrWhiteSpace(successMessage))
                {
                    <div class="message success">@successMessage</div>
                }

                <div class="auth-footer">
                    <p>
                        Already have an account?
                        <a href="/login">Sign In</a>
                    </p>
                </div>

            </div>
        </div>

    </div>
</div>

@code {

    private sealed class RegisterModel
    {
        [Required]
        [MinLength(3)]
        public string Username { get; set; } = string.Empty;

        [Required]
        [EmailAddress]
        public string Email { get; set; } = string.Empty;

        [Required]
        [MinLength(6)]
        public string Password { get; set; } = string.Empty;

        [Required]
        public string Name { get; set; } = string.Empty;

        [Range(18, 120)]
        public int Age { get; set; }

        [Required]
        public string Gender { get; set; } = string.Empty;

        [Required]
        public string LookingFor { get; set; } = string.Empty;
    }

    private RegisterModel registerData = new();

    private string successMessage = string.Empty;

    private void HandleRegister()
    {
        successMessage = "Account created (front-end demo)";
    }
}