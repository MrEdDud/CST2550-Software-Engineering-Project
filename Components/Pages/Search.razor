@page "/search"
@using CST2550Project.DTOs
@using CST2550Project.Services
@inject ProfileService ProfileService

<div class="page">
    <h1 class="page-title">Discover</h1>
    <p class="page-subtitle">People near you</p>

    <div class="form-group" style="margin-bottom:16px;">
        <input class="form-control"
               placeholder="Search by name, bio, location, occupation..."
               @bind="SearchTerm" />
    </div>

    <div class="form-group" style="margin-bottom:16px;">
        <select class="form-control" @bind="SelectedGender">
            <option value="">Everyone</option>
            <option value="Male">Men</option>
            <option value="Female">Women</option>
        </select>
    </div>

    <div class="form-group" style="margin-bottom:16px;">
        <label>Min Age</label>
        <input class="form-control" type="number" @bind="MinAge" />
    </div>

    <div class="form-group" style="margin-bottom:16px;">
        <label>Max Age</label>
        <input class="form-control" type="number" @bind="MaxAge" />
    </div>

    <div style="margin-bottom:24px;">
        <button class="btn btn-primary" @onclick="LoadProfilesAsync">
            Apply Search
        </button>
    </div>

    @if (isLoading)
    {
        <div class="empty-state">
            <div class="loading-card">
                <div class="loader"></div>
                <p>Loading profiles...</p>
            </div>
        </div>
    }
    else if (profiles.Count == 0)
    {
        <div class="empty-state">
            <div class="empty-icon">
                <i class="fas fa-search"></i>
            </div>
            <h2>No profiles found</h2>
            <p>Try changing your search or filters.</p>
        </div>
    }
    else
    {
        <div class="card-grid">
            @foreach (var p in profiles)
            {
                <div class="profile-card">
                    <div class="profile-photo">
                        <span class="profile-initial">
                            @(string.IsNullOrWhiteSpace(p.Name) ? "?" : p.Name.Substring(0, 1))
                        </span>
                    </div>

                    <div class="profile-info">
                        <div class="profile-name">
                            @p.Name
                            <span class="profile-age">@p.Age</span>
                        </div>

                        <div class="profile-bio">@p.Bio</div>
                    </div>

                    <div class="profile-actions">
                        <button class="icon-btn nope"
                                @onclick='() => HandleAction("Nope", p.Name)'>
                            ✕
                        </button>

                        <button class="icon-btn like"
                                @onclick='() => HandleAction("Like", p.Name)'>
                            ❤
                        </button>
                    </div>
                </div>
            }
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(lastAction))
    {
        <div class="toast">@lastAction</div>
    }
</div>

@code {
    private List<ProfileDto> profiles = new();
    private bool isLoading = true;
    private string lastAction = string.Empty;

    private string SearchTerm = string.Empty;
    private string SelectedGender = string.Empty;
    private int? MinAge = 18;
    private int? MaxAge = 35;

    private const int DemoUserId = 1;

    protected override async Task OnInitializedAsync()
    {
        await LoadProfilesAsync();
    }

    private async Task LoadProfilesAsync()
    {
        isLoading = true;

        var filter = new DiscoverFilterDto
        {
            SearchTerm = SearchTerm,
            Gender = SelectedGender,
            MinAge = MinAge,
            MaxAge = MaxAge,
            Count = 50
        };

        profiles = await ProfileService.GetDiscoveryProfilesAsync(DemoUserId, filter);

        isLoading = false;
    }

    private void HandleAction(string action, string name)
    {
        if (action == "Like")
        {
            lastAction = $"❤️ You liked {name}";
        }
        else
        {
            lastAction = $"❌ You skipped {name}";
        }
    }
}