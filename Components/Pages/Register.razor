@page "/register"
@using System.ComponentModel.DataAnnotations
@inject NavigationManager Navigation
@layout AuthLayout

<div class="auth-header">
    <h2>Create Account</h2>
    <p>Start your journey to find love on Pairly</p>
</div>

<EditForm Model="@registerData"
            OnValidSubmit="@HandleRegister"
            class="auth-form">

    <DataAnnotationsValidator />

    <div class="form-group">
        <label><i class="fas fa-id-card"></i> Your Name</label>

        <InputText class="form-control"
                    @bind-Value="registerData.Name"
                    placeholder="What should we call you?" />

        <ValidationMessage For="@(() => registerData.Name)" />
    </div>

    <div class="form-group">
        <label><i class="fas fa-envelope"></i> Email</label>

        <InputText class="form-control"
                    @bind-Value="registerData.Email"
                    placeholder="your@email.com" />

        <ValidationMessage For="@(() => registerData.Email)" />
    </div>

    <div class="form-group">
        <label><i class="fas fa-lock"></i> Password</label>

        <InputText type="password"
                    class="form-control"
                    @bind-Value="registerData.Password"
                    placeholder="Create a strong password" />

        <ValidationMessage For="@(() => registerData.Password)" />
    </div>

    <div class="form-group">
        <label><i class="fas fa-lock"></i> Confirm Password</label>

        <InputText type="password"
                    class="form-control"
                    @bind-Value="registerData.ConfPassword"
                    placeholder="Write your password again" />

        <ValidationMessage For="@(() => registerData.ConfPassword)" />
    </div>

    <div class="form-group">
        <label><i class="fas fa-birthday-cake"></i> Age</label>

        <InputNumber class="form-control"
                        @bind-Value="registerData.Age" />

        <ValidationMessage For="@(() => registerData.Age)" />
    </div>

    <button type="submit" class="btn btn-primary btn-block">
        <span>Next</span>
        <i class="fas fa-check"></i>
    </button>

</EditForm>

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="message success">@successMessage</div>
}

<div class="auth-footer">
    <p>
        Already have an account?
        <NavLink href="/login">Sign In</NavLink>
    </p>
</div>

@code {
    private sealed class RegisterModel
    {
        [Required(ErrorMessage = "Your username is required")]
        public string Name { get; set; } = string.Empty;

        [Required(ErrorMessage = "Your email is required")]
        [EmailAddress]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "You must create a password")]
        [MinLength(6)]
        public string Password { get; set; } = string.Empty;

		[Required(ErrorMessage = "You must confirm your password")]
        [Compare("Password")]
        public string ConfPassword { get; set; } = string.Empty;

		[Required]
        [Range(18, 120, ErrorMessage = "You must be at least 18 years old")]
        public int Age { get; set; }
    }

    private RegisterModel registerData = new();

    private string successMessage = string.Empty;

    private void HandleRegister()
    {
        successMessage = "Success!";
        Navigation.NavigateTo("/details", true);
    }
}