@page "/login"
@using System.ComponentModel.DataAnnotations

<!--
    LOGIN PAGE (Front-end only)
    - Uses EditForm + DataAnnotations validation
    - No backend calls yet
    - Shows validation errors + a demo success message
-->

<div class="login-container">
    <div class="login-card">

        <!-- Branding / Heading -->
        <h2 class="app-title">Pairly</h2>
        <p class="subtitle">Sign in to continue</p>

        <!--
            EditForm:
            - Model binds the form to our C# object (loginData)
            - OnValidSubmit runs only when validation passes
        -->
        <EditForm Model="@loginData" OnValidSubmit="@HandleLogin">

            <!-- Enables DataAnnotations validation -->
            <DataAnnotationsValidator />

            <!-- Shows a summary of validation errors -->
            <ValidationSummary />

            <!-- EMAIL -->
            <div class="form-group">
                <label>Email</label>

                <!--
                    InputText:
                    - Blazor input component
                    - @bind-Value keeps loginData.Email in sync with the UI
                -->
                <InputText class="form-control"
                           @bind-Value="loginData.Email"
                           placeholder="you@university.ac.uk" />

                <!-- Field-specific validation message -->
                <ValidationMessage For="@(() => loginData.Email)" />
            </div>

            <!-- PASSWORD -->
            <div class="form-group">
                <label>Password</label>

                <!--
                    type="password" hides characters
                    Bound to loginData.Password
                -->
                <InputText type="password"
                           class="form-control"
                           @bind-Value="loginData.Password"
                           placeholder="Enter your password" />

                <ValidationMessage For="@(() => loginData.Password)" />
            </div>

            <!-- Submit -->
            <button type="submit" class="btn-login">
                Login
            </button>
        </EditForm>

        <!-- Demo success message (front-end only) -->
        @if (!string.IsNullOrWhiteSpace(successMessage))
        {
            <div class="message success">@successMessage</div>
        }

        <!-- Link to Register page -->
        <div class="register-link">
            Don’t have an account?
            <a href="/register">Create one</a>
        </div>

    </div>
</div>

@code {
    /*
        IMPORTANT:
        - Class/type names must be PascalCase.
        - DO NOT name a type 'login' (lowercase), it triggers CS8981.
    */
    private sealed class LoginModel
    {
        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Enter a valid email address.")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Password is required.")]
        [MinLength(6, ErrorMessage = "Password must be at least 6 characters.")]
        public string Password { get; set; } = string.Empty;
    }

    // This is the form model instance used by EditForm (note camelCase for variables)
    private LoginModel loginData = new();

    // Used to show a demo message after valid submit
    private string successMessage = string.Empty;

    /*
        Runs ONLY if validation passes.
        Front-end only: we just show a success message.
        Later you will replace this with an API call.
    */
    private void HandleLogin()
    {
        successMessage = "Login successful (front-end demo).";
    }
}
