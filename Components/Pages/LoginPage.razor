@page "/login"
@using System.ComponentModel.DataAnnotations

<div class="auth-page">
    <div class="auth-container">

        <!-- Left side -->
        <div class="auth-brand">
            <div class="brand-content">

                <div class="brand-logo">
                    <i class="fas fa-heart"></i>
                </div>

                <h1>Pairly</h1>
                <p>Find meaningful connections with people who share your interests and values. (18+)</p>

                <div class="brand-features">
                    <div class="feature"><i class="fas fa-shield-alt"></i><span>Safe & Secure</span></div>
                    <div class="feature"><i class="fas fa-users"></i><span>Verified Profiles</span></div>
                    <div class="feature"><i class="fas fa-heart"></i><span>Real Connections</span></div>
                </div>

            </div>

            <div class="brand-decoration">
                <div class="floating-heart"></div>
                <div class="floating-heart"></div>
                <div class="floating-heart"></div>
            </div>
        </div>

        <!-- Right side -->
        <div class="auth-form-container">
            <div class="auth-form-wrapper">

                <div class="auth-header">
                    <h2>Welcome Back</h2>
                    <p>Sign in to continue to Pairly</p>
                </div>

                <EditForm Model="loginData" OnValidSubmit="HandleLogin" class="auth-form">

                    <DataAnnotationsValidator />

                    <div class="form-group">
                        <label><i class="fas fa-user"></i> Username</label>
                        <InputText class="form-control"
                                   @bind-Value="loginData.Username"
                                   placeholder="Enter your username" />
                        <ValidationMessage For="@(() => loginData.Username)" />
                    </div>

                    <div class="form-group">
                        <label><i class="fas fa-lock"></i> Password</label>
                        <InputText type="password"
                                   class="form-control"
                                   @bind-Value="loginData.Password"
                                   placeholder="Enter your password" />
                        <ValidationMessage For="@(() => loginData.Password)" />
                    </div>

                    <button type="submit" class="btn btn-primary btn-block">
                        Sign In
                    </button>

                </EditForm>

                <div class="auth-footer">
                    <p>Don't have an account? <a href="/register">Sign Up</a></p>
                </div>

            </div>
        </div>

    </div>
</div>

@code {
    class LoginModel
    {
        [Required]
        public string Username { get; set; } = string.Empty;

        [Required, MinLength(6)]
        public string Password { get; set; } = string.Empty;
    }

    private LoginModel loginData = new();

    private string successMessage = string.Empty;

    private void HandleLogin()
    {
        successMessage = "Login successful (front-end demo)";
    }
}