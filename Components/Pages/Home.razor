@page "/"
@page "/home"

@* Sidebar *@
<aside class="app-sidebar">
    <div class="sidebar-profile">
        <i class="fa-regular fa-circle-user sidebar-avatar"></i>
        <strong id="sidebarName">You</strong> <span id="sidebarHandle">@@<span id="sidebarUsername">user</span></span>
    </div>
    <nav class="sidebar-nav">
        @foreach (var item in SidebarItems)
        {
            <button class="sidebar-link @(currentTab == item.Id ? "active" : "")" @onclick="() => SwitchTab(item.Id)">
                <i class="@item.Icon"></i>
                <span>@item.Text</span>
            </button>
        }
    </nav>
    @* Needs fixing ↓↓↓↓↓ *@

    @* <div class="sidebar-bottom">
        <button class="btn" onclick="logout()">Logout</button>
    </div> *@
</aside>

<main>
    @* Switches to different pages depending on which button has been pressed *@
    @switch (currentTab)
    {
        case "home":
            @* Switches to HomeTab.razor which is a child of Home.razor *@
            <HomeTab />
            break;

        case "matches":
            <MatchesTab />
            break;

        case "profile":
            <ProfileTab />
            break;

        case "settings":
            <SettingsTab />
            break;

        @* You can add another case for searching aswell and make search a child of Home.razor -Ed *@
    }
</main>

@code {
    private record NavItem(string Id, string Icon, string Text, bool Active = false);

    private readonly List<NavItem> SidebarItems = new()
    {
        new("home", "fas fa-fire", "Home", true),
        new("matches", "fas fa-heart", "Matches"),
        new("profile", "fas fa-user", "Profile"),
        new("settings", "fas fa-cog", "Settings")
    };

    // UI state
    private string currentTab = "home";

    private void SwitchTab(string id)
    {
        currentTab = id;
        // update BottomTabs/SidebarItems active flags if you need them elsewhere
    }
}
