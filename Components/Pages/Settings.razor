@page "/settings"

<div class="settings-page">

    <h1 class="settings-title">Settings</h1>

    <div class="settings-search">
        <input type="text" placeholder="Search for a setting..." @bind="searchText" />
    </div>

    <div class="settings-list">

        <button class="settings-item"
                @onclick='() => SelectSetting("Account")'>
            <span class="settings-left">
                <span class="settings-dot"></span>
                <span>Account</span>
            </span>
            <span class="settings-arrow">></span>
        </button>

        <button class="settings-item"
                @onclick='() => SelectSetting("Notifications")'>
            <span class="settings-left">
                <span class="settings-dot"></span>
                <span>Notifications</span>
            </span>
            <span class="settings-arrow">></span>
        </button>

        <button class="settings-item"
                @onclick='() => SelectSetting("Theme")'>
            <span class="settings-left">
                <span class="settings-dot"></span>
                <span>Theme</span>
            </span>
            <span class="settings-arrow">></span>
        </button>

        <button class="settings-item"
                @onclick='() => SelectSetting("Privacy")'>
            <span class="settings-left">
                <span class="settings-dot"></span>
                <span>Privacy</span>
            </span>
            <span class="settings-arrow">></span>
        </button>

        <button class="settings-item"
                @onclick='() => SelectSetting("About")'>
            <span class="settings-left">
                <span class="settings-dot"></span>
                <span>About</span>
            </span>
            <span class="settings-arrow">></span>
        </button>

    </div>

    <button class="signout-btn" @onclick="HandleSignOut">
        SIGN OUT
    </button>

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="message success">@statusMessage</div>
    }

</div>

@code {
    private string searchText = string.Empty;
    private string statusMessage = string.Empty;

    private void SelectSetting(string settingName)
    {
        statusMessage = $"{settingName} clicked";
    }

    private void HandleSignOut()
    {
        statusMessage = "Signed out (front-end demo)";
    }
}