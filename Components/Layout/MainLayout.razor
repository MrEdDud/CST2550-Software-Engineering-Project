@inherits LayoutComponentBase

<div class="app-shell">

    <!-- Top bar -->
    <header class="topbar">
        <div class="brand">
            <i class="fa-solid fa-heart"></i>
            <span class="brand-name">Pairly</span>
        </div>

        <div class="topbar-actions">
            <button class="header-btn">
                <i class="fas fa-bell"></i>
            </button>
        </div>
    </header>

    <div class="app-content">

        <!-- Sidebar -->
        <aside class="app-sidebar">

            <div class="sidebar-profile">
                <i class="fa-regular fa-circle-user sidebar-avatar"></i>
                <strong>You</strong>
                <span>@@user</span>
            </div>

            <nav class="sidebar-nav">

                <NavLink href="/home" class="sidebar-link">
                    <i class="fas fa-fire"></i>
                    <span>Home</span>
                </NavLink>

                <NavLink href="/matches" class="sidebar-link">
                    <i class="fas fa-heart"></i>
                    <span>Matches</span>
                </NavLink>

                <NavLink href="/profile" class="sidebar-link">
                    <i class="fas fa-user"></i>
                    <span>Profile</span>
                </NavLink>

                <NavLink href="/settings" class="sidebar-link">
                    <i class="fas fa-cog"></i>
                    <span>Settings</span>
                </NavLink>

                <div class="sidebar-search">

                    <i class="fas fa-search"></i>

                    <input type="text"
                           placeholder="Search..."
                           @bind="SearchTerm"
                           @bind:event="oninput" />

                    <button class="filter-btn"
                            @onclick="ToggleFilters">
                        <i class="fas fa-sliders-h"></i>
                    </button>

                </div>

            </nav>

        </aside>

        <!-- Page content -->
        <main class="app-main">
            @Body
        </main>

        <div class="filter-panel @(ShowFilters ? "open" : "")">

            <div class="filter-header">
                <h3>Filters</h3>
                <button @onclick="ToggleFilters">✖</button>
            </div>

            <div class="filter-content">

                <!-- Age -->
                <label>Age: @MinAge - @MaxAge</label>
                <input type="range" min="18" max="65" @bind="MinAge" />
                <input type="range" min="18" max="65" @bind="MaxAge" />

                <!-- Gender -->
                <label>Show Me</label>
                <select @bind="SelectedGender">
                    <option value="">Everyone</option>
                    <option value="Female">Women</option>
                    <option value="Male">Men</option>
                </select>

            </div>

            <div class="filter-actions">
                <button @onclick="ResetFilters">Reset</button>
                <button @onclick="ApplyFilters">Apply</button>
            </div>

        </div>

    </div>

</div>

@code {

    string SearchTerm = "";

    bool ShowFilters = false;

    int MinAge = 18;
    int MaxAge = 35;

    string SelectedGender = "";

    void ToggleFilters()
    {
        ShowFilters = !ShowFilters;
    }

    void ResetFilters()
    {
        MinAge = 18;
        MaxAge = 35;
        SelectedGender = "";
    }

    void ApplyFilters()
    {
        // later: filter profiles here
        ShowFilters = false;
    }
}