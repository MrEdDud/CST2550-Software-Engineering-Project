@inherits LayoutComponentBase

<div class="app-shell">
    <!-- Top bar -->
    <header class="topbar">
        @* App logo and name *@
        <div class="brand">
            <i class="fa-solid fa-heart"></i>
            <span class="brand-name">Pairly</span>
        </div>

        <nav class="topnav">
            @* /// Future code for search icon *@
            <span>Future search bar</span>
            @* /// Future code for filters button *@
        </nav>

        @* Notification button *@
        <div class="topbar-actions">
            <button class="header-btn">
                <i class="fas fa-bell"></i>
                <span class="notification-dot" id="notificationDot"></span>
            </button>
        </div>
    </header>

    <!-- Page content -->
    <main class="app-content">
        @Body
    </main>
</div>