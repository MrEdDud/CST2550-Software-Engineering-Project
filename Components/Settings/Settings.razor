@page "/settings"
@inject SessionService Session
@inject NavigationManager Nav

<div class="settings-page">

    <h1 class="settings-title">Settings</h1>

    <div class="settings-search">
        <input type="text" placeholder="Search for a setting..." @bind="searchText" />
    </div>

    <div class="settings-list">

        <button class="settings-item"
                @onclick='() => SelectSetting("Account")'>
            <span class="settings-left">
                <i class="fa-solid fa-circle-user"></i>
                <span>Account</span>
            </span>
            <span class="settings-arrow">></span>
        </button>

        <button class="settings-item"
                @onclick='() => SelectSetting("Notifications")'>
            <span class="settings-left">
                <i class="fa-solid fa-bell"></i>
                <span>Notifications</span>
            </span>
            <span class="settings-arrow">></span>
        </button>

        <button class="settings-item"
                @onclick='() => SelectSetting("Theme")'>
            <span class="settings-left">
                <i class="fa-solid fa-brush"></i>
                <span>Theme</span>
            </span>
            <span class="settings-arrow">></span>
        </button>

        <button class="settings-item"
                @onclick='() => SelectSetting("Privacy")'>
            <span class="settings-left">
                <i class="fa-solid fa-lock"></i>
                <span>Privacy</span>
            </span>
            <span class="settings-arrow">></span>
        </button>

        <button class="settings-item"
                @onclick='() => SelectSetting("About")'>
            <span class="settings-left">
                <i class="fa-solid fa-circle-info"></i>
                <span>About</span>
            </span>
            <span class="settings-arrow">></span>
        </button>

    </div>

    <button class="signout-btn" @onclick="HandleSignOut">
        SIGN OUT
    </button>

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="message success">@statusMessage</div>
    }

</div>

@code {
    private string searchText = string.Empty;
    private string statusMessage = string.Empty;

    private void SelectSetting(string settingName)
    {
        switch (settingName)
        {
            case "Account":
                Nav.NavigateTo("/settings/account");
                break;

            case "Notifications":
                Nav.NavigateTo("/settings/notifications");
                break;

            case "Privacy":
                Nav.NavigateTo("/settings/privacy");
                break;

            case "About":
                Nav.NavigateTo("/settings/about");
                break;
        }
    }

    private void HandleSignOut()
    {
        Session.Logout();
        statusMessage = "Signed out successfully";

        // Redirect to login page
        Nav.NavigateTo("/login", forceLoad: true);
    }
}