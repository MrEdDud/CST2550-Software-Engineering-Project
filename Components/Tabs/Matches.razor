@page "/matches"
@using CST2550Project.Models
@inject NavigationManager NavigationManager

<div class="matches-container">
    <div class="matches-panel">
        <div class="matches-header">
            <i class="fa-regular fa-envelope"></i>
            <span>Match Requests</span>
        </div>

        @if (MatchList.Any())
        {
            <ul class="match-list">
                @foreach (var match in MatchList)
                {
                    var other = GetOtherUser(match);
                    <li class="match-item" @onclick="() => NavigateToMatch(match)">
                        <div class="avatar">
                            <span class="avatar-fallback">@other.Username[0]</span>
                        </div>
                        <div class="match-info">
                            <span class="match-name">@other.Username</span>
                            <span class="match-last-message">
                                @(match.Messages.LastOrDefault()?.Content ?? "No messages yet.")
                            </span>
                        </div>
                        <span class="match-timestamp">
                            @(match.Messages.LastOrDefault()?.SentAt.ToString("MMM dd") ?? "")
                        </span>
                    </li>
                }
            </ul>
        }
        else
        {
            <div class="no-matches">
                <p>No match requests yet.</p>
            </div>
        }
    </div>
</div>

@code {
    private int CurrentUserId = 1; 
    private List<Match> MatchList = new();

    protected override async Task OnInitializedAsync()
    {
        MatchList = await GetMatchesFromDb();
    }

    private async Task<List<Match>> GetMatchesFromDb()
    {
        var user1 = new User { Id = 1, Username = "You" };
        var user2 = new User { Id = 2, Username = "Alex" };
        var user3 = new User { Id = 3, Username = "Jordan" };

        return new List<Match>
        {
            new Match
            {
                Id = 1, User1 = user1, User2 = user2,
                Messages = new List<Message>
                {
                    new Message { Content = "Hey, how's it going?", SenderId = 2, SentAt = DateTime.Now.AddHours(-2) }
                }
            },
            new Match
            {
                Id = 2, User1 = user1, User2 = user3,
                Messages = new List<Message>()
            }
        };
    }

    private User GetOtherUser(Match match)
    {
        if (match.User1 == null || match.User2 == null)
        {
            return new User { Username = "Unknown" };
        }
        return match.User1.Id == CurrentUserId ? match.User2 : match.User1;
    }

    private void NavigateToMatch(Match match)
    {
        // This can navigate to a chat page if you decide to implement it later
        // For now, it does nothing.
    }
}
