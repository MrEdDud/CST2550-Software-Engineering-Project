@page "/"
@page "/home"

<section>
    <div class="discovery-container">
        <div class="card-stack">

            @if (IsLoading)
            {
                <div class="loading-card">
                    <div class="loader"></div>
                    <p>Finding people near you...</p>
                </div>
            }
            else if (noMoreProfiles)
            {
                <div class="empty-state">
                    <div class="empty-icon">
                        <i class="fas fa-heart-broken"></i>
                    </div>
                    <h2>No more profiles</h2>
                    <p>You've seen everyone for now. Check back later for new people!</p>
                    <button class="btn btn-primary" @onclick="LoadProfiles">
                        <i class="fas fa-sync-alt"></i> Refresh
                    </button>
                </div>
            }
            else
            {
                <SwipeCard Profiles="Profiles"
                           OnSwipe="HandleSwipe" />
            }

        </div>
    </div>
</section>

<div class="toast-container"></div>

@code {
    private List<ProfileModel> Profiles = new();

    private bool noMoreProfiles = false;
    private bool IsLoading = true;

    [Inject]
    private NavigationManager NavigationManager { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        await LoadProfiles();
    }

    private async Task LoadProfiles()
    {
        IsLoading = true;
        noMoreProfiles = false;

        // 🔌 Replace with your API later
        await Task.Delay(1000);

        // TEMP MOCK DATA (remove when API ready)
        Profiles = new List<ProfileModel>
        {
            new ProfileModel { UserId = 1, Name = "Anna", Age = 21, Bio = "Loves coffee ☕", ProfilePhotoUrl = "https://via.placeholder.com/300" },
            new ProfileModel { UserId = 2, Name = "Sophie", Age = 23, Bio = "Gym & travel", ProfilePhotoUrl = "https://via.placeholder.com/300" }
        };

        IsLoading = false;
        noMoreProfiles = Profiles.Count == 0;
    }

    private async Task HandleSwipe((ProfileModel profile, bool isLike) data)
    {
        // 🔌 Send to API later
        // await Api.Swipe(...)

        Profiles.Remove(data.profile);

        if (Profiles.Count == 0)
        {
            noMoreProfiles = true;
        }

        await Task.CompletedTask;
    }

    private void NavigateToProfile()
    {
        NavigationManager.NavigateTo("/profile");
    }
}