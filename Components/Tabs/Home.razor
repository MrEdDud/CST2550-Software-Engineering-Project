@page "/"
@page "/home"

@using CST2550Project.Services
@using CST2550Project.Models
@using CST2550Project.DTOs

<section style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: calc(100vh - 140px);">
    <div class="discovery-container" style="width: 100%; display: flex; align-items: center; justify-content: center;">
        <div class="card-stack" style="margin: 0 auto; position: relative;">

            @if (IsLoading)
            {
                <div class="loading-card">
                    <div class="loader"></div>
                    <p>Finding people near you...</p>
                </div>
            }
            else if (noMoreProfiles)
            {
                <div class="empty-state">
                    <div class="empty-icon">
                        <i class="fas fa-heart-broken"></i>
                    </div>
                    <h2>No More Profiles</h2>
                    <p>You have reached your limit, please check back later for new profiles !</p>
                    <button class="btn btn-primary" @onclick="LoadProfiles">
                        <i class="fas fa-sync-alt"></i> Refresh
                    </button>
                </div>
            }
            else
            {
                <SwipeCard Profiles="Profiles" OnSwipe="@HandleSwipe" />
            }

        </div>
    </div>
</section>

<div class="toast-container"></div>

@code {
    private List<ProfileDto> Profiles = new();

    private bool noMoreProfiles = false;
    private bool IsLoading = true;

    [Inject]
    private NavigationManager NavigationManager { get; set; } = default!;

    [Inject]
    private ProfileService ProfileService { get; set; } = default!;

    [Inject]
    private AuthService AuthService { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        await LoadProfiles();
    }

    private async Task LoadProfiles()
    {
        IsLoading = true;
        noMoreProfiles = false;

        // Using user Id = 1 for now (demo mode)
        int userId = 1;

        var filter = new DiscoverFilterDto
        {
            Gender = SelectedGender,
            MinAge = MinAge,
            MaxAge = MaxAge,
            SearchTerm = SearchTerm,
            Count = 20
        };

        Profiles = await ProfileService.GetDiscoveryProfilesAsync(userId, filter);

        IsLoading = false;
        noMoreProfiles = Profiles.Count == 0;
    }

    private async Task HandleSwipe((ProfileDto profile, bool isLike) data)
    {
        // In the future:
        // if (data.isLike) await ProfileService.LikeProfileAsync(userId, data.profile.UserId);
        // else ...

        Profiles.RemoveAll(p => p.UserId == data.profile.UserId);

        if (Profiles.Count == 0)
        {
            noMoreProfiles = true;
            // Optionally try to load more automatically
            // await LoadProfiles();
        }

        await Task.CompletedTask;
    }

    private void NavigateToProfile()
    {
        NavigationManager.NavigateTo("/profile");
    }

    private string SearchTerm = "";
    private bool ShowFilters = false;

    private int MinAge = 18;
    private int MaxAge = 35;
    private string SelectedGender = "";
}