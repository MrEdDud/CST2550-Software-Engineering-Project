    private async Task HandleSwipe((ProfileModel profile, bool isLike) data)
    {
        // 🔌 Send to API later
        // await Api.Swipe(...)

        Profiles.RemoveAll(p => p.UserId == data.profile.UserId);

        if (Profiles.Count == 0)
        {
            noMoreProfiles = true;
        }

        await Task.CompletedTask;
    }

    private void NavigateToProfile()
    {
        NavigationManager.NavigateTo("/profile");
    }

    private string SearchTerm = "";
