@page "/login"
@using System.ComponentModel.DataAnnotations
@using CST2550Project.DTOs
@inject HttpClient Http
@inject AuthService AuthService
@inject SessionService Session
@inject NavigationManager Navigation
@layout AuthLayout

<div class="auth-header">
    <h2>Welcome Back</h2>
    <p>Sign in to continue to Pairly</p>
</div>

<EditForm Model="loginData" OnValidSubmit="HandleLogin" class="auth-form">

    <DataAnnotationsValidator />

    <div class="form-group">
        <label><i class="fas fa-user"></i> Username</label>
        <InputText class="form-control"
                    @bind-Value="loginData.Username"
                    placeholder="Enter your username" />
        <ValidationMessage For="@(() => loginData.Username)" />
    </div>
                    
    <div class="form-group">
        <label><i class="fas fa-lock"></i> Password</label>
        <InputText type="password"
                    class="form-control"
                    @bind-Value="loginData.Password"
                    placeholder="Enter your password" />
        <ValidationMessage For="@(() => loginData.Password)" />
    </div>

    <button type="submit" class="btn btn-primary btn-block">
        Sign In
    </button>

    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="text-danger mt-2">@successMessage</div>
    }

</EditForm>

<div class="auth-footer">
    <p>Don't have an account? <a href="/register">Sign Up</a></p>
</div>

@code {
    class LoginModel
    {
        [Required(ErrorMessage = "Please enter your username")]
        public string Username { get; set; } = string.Empty;

        [Required(ErrorMessage = "Please enter your password"), MinLength(6)]
        public string Password { get; set; } = string.Empty;
    }

    private LoginModel loginData = new();

    private string successMessage = string.Empty;

    private async Task HandleLogin()
    {
        var dto = new LoginDto
        {
            Username = loginData.Username,
            Password = loginData.Password
        };

        var response = await Http.PostAsJsonAsync("api/auth/login", dto);

        if (response.IsSuccessStatusCode)
        {
            var authResult = await response.Content.ReadFromJsonAsync<AuthResponseDto>();

            if (authResult != null)
            {
                // Use the proper method instead of setting read-only properties
                await Session.SetSessionAsync(
                    authResult.UserId,
                    authResult.Username,
                    authResult.Token,
                    authResult.HasProfile
                );

                Navigation.NavigateTo("/");
            }
        }
        else
        {
            successMessage = "Invalid username or password";
        }
    }
}